# Sanity CMS project connection
# Create a free project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-01
SANITY_API_READ_TOKEN=your_read_token_if_dataset_is_private

# Site
NEXT_PUBLIC_SITE_URL=https://www.calticbaru.com

# Note: this project has no server-side form handling — all "Request a
# Quotation" CTAs open a WhatsApp modal (see docs/WHATSAPP-CONTACT.md).
# No write token or notification email is required for that flow.

# On-demand content revalidation — see docs/CONTENT-REVALIDATION.md.
# Set this to a random string and configure the same value as a query
# param on your Sanity webhook so new products/categories go live instantly.
SANITY_REVALIDATE_SECRET=choose_a_random_string
